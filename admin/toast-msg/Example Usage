if (!isset($_SESSION['admin_id'])) {
    header("Location: login.php");
    exit;
}

// Example: Handle form submission
if ($_SERVER["REQUEST_METHOD"] == "POST") {
    if (isset($_POST['add_student'])) {
        // Simulate successful student addition
        toastSuccess('Student added successfully!', 'New Student', 4000);
    }
    
    if (isset($_POST['delete_student'])) {
        // Simulate error
        toastError('Failed to delete student. Please try again.', 'Error', 5000);
    }
    
    if (isset($_POST['update_payment'])) {
        // Simulate warning
        toastWarning('Payment is pending for this student.', 'Payment Due', 6000);
    }
    
    if (isset($_POST['bulk_action'])) {
        // Multiple toasts example
        setMultipleToasts([
            [
                'message' => '5 students imported successfully',
                'type' => 'success',
                'title' => 'Import Complete',
                'duration' => 4000
            ],
            [
                'message' => '2 students had duplicate entries',
                'type' => 'warning',
