            ],
            [
                'message' => 'Database updated successfully',
                'type' => 'info',
                'title' => 'System Update',
                'duration' => 3000
            ]
        ]);
    }
}

// Example AJAX handler
if (isset($_GET['ajax_action'])) {
    sendToastResponse('AJAX operation completed!', 'success', 'AJAX Success');
